# Render worker environment variables
# Copy these into your Render Background Worker service settings.

# Backblaze B2
B2_BUCKET_NAME=reels-output
B2_APPLICATION_KEY=replace_me
B2_APPLICATION_KEY_ID=replace_me
# Use the endpoint matching your B2 bucket region.
# Example for us-west: https://s3.us-west-000.backblazeb2.com
B2_ENDPOINT=replace_me

# AI providers
ANTHROPIC_API_KEY=replace_me
ANTHROPIC_MODEL=claude-3-5-haiku-20241022
REPLICATE_API_TOKEN=replace_me
ELEVENLABS_API_KEY=replace_me
ELEVENLABS_VOICE_ID=reels_voice

# Queue + database
REDIS_URL=replace_me
DATABASE_URL=replace_me

# Workflow callbacks and runtime
N8N_CALLBACK_URL=https://replace_me/webhook/render-callback
WORKER_REGION=us-west
LOG_LEVEL=info
TEMP_DIR=/tmp/reels
MAX_RETRIES=2
JOB_TIMEOUT_SECONDS=360

# Monitoring
SENTRY_DSN=replace_me
