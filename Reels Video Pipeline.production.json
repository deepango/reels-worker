      "parameters": {
        "respondWith": "json",
        "responseCode": 402,
        "responseBody": "={{ { ok: false, error: 'No videos remaining. Please upgrade your plan.' } }}",
        "options": {}
      },
      "id": "respond-no-quota",
      "name": "Respond - No Quota",
