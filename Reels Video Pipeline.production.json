    {
      "parameters": {
        "method": "POST",
        "url": "https://api.anthropic.com/v1/messages",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ {\"model\": \"claude-haiku-4-5\", \"max_tokens\": 4096, \"system\": [{\"type\": \"text\", \"text\": \"You are a real-estate video reel scriptwriter specialising in Indian and global property markets. Respond with ONLY a raw JSON object — no markdown, no code fences, no explanation. Your entire response must parse as valid JSON. Output a single object with one key: scenes (array of exactly 5 objects). Each object: scene_id (integer 1-5), image_prompt (a photorealistic prompt: shot type + subject with architectural details + lighting + mood — always end with: photorealistic, 9:16 vertical, no text, no people, no watermarks, ultra-detailed), voiceover_text (12-18 spoken words, conversational, punchy, present tense, no hashtags, no emojis). Scene 1 = strong exterior hook. Scenes 2-4 = interior highlights. Scene 5 = CTA or emotional close.\", \"cache_control\": {\"type\": \"ephemeral\"}}], \"messages\": [{\"role\": \"user\", \"content\": \"Write a 5-scene real-estate Reel script for: \" + $(\"Webhook - Generate Video\").item.json.body.topic}]} }}",
        "options": {
          "response": {
            "response": {
              "responseFormat": "json"
            }
          }
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "anthropic-beta",
              "value": "prompt-caching-2024-07-31"
            }
          ]
        }
      },
      "id": "anthropic-generate",
      "name": "Anthropic - Generate Script",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        1300,
        300
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "REPLACE_ANTHROPIC_CRED_ID",
          "name": "anthropic"
        }
      }
    },
    {
      "parameters": {
        "assignments": {
          "assignments": [
            {
              "name": "job_id",
              "type": "number",
              "value": "={{$(\"Postgres - Insert Job\").item.json.id}}"
            },
            {
              "name": "topic",
              "type": "string",
              "value": "={{$(\"Webhook - Generate Video\").item.json.body.topic}}"
            },
            {
              "name": "customer_id",
              "type": "number",
              "value": "={{$(\"Webhook - Generate Video\").item.json.body.customer_id}}"
            },
            {
              "name": "scenes",
              "type": "array",
              "value": "={{ (() => { const t = $json.content[0].text.trim(); try { return JSON.parse(t).scenes; } catch(e) {} const m = t.match(/```(?:json)?\\s*([\\s\\S]*?)```/); return JSON.parse(m ? m[1].trim() : t).scenes; })() }}"
            }
          ]
        }
      },
      "id": "set-script-context",
      "name": "Set - Script Context",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [
        1540,
        300
