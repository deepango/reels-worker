{
  "name": "Reels Video Pipeline (Production)",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "generate-video",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook-generate",
      "name": "Webhook - Generate Video",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2.1,
      "position": [
        200,
        300
      ]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT videos_remaining FROM customers WHERE id = $1",
        "additionalFields": {
          "queryParams": "={{$json.body.customer_id}}"
        }
      },
      "id": "pg-check-quota",
      "name": "Postgres - Check Quota",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.6,
      "position": [
        420,
        300
      ],
      "credentials": {
        "postgres": {
          "id": "REPLACE_POSTGRES_CRED_ID",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "conditions": {
          "number": [
            {
              "value1": "={{$json.videos_remaining}}",
              "operation": "larger",
              "value2": 0
            }
          ]
        }
      },
      "id": "if-has-quota",
      "name": "IF - Has Quota",
